{
  "name": "@cloakedxyz/clkd-stealth",
  "version": "1.1.1",
  "description": "Core stealth address tools for Cloaked",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "stealth-addresses",
    "eip-5564",
    "privacy",
    "ethereum",
    "cryptography",
    "hd-wallet",
    "bip-32",
    "cloaked"
  ],
  "author": "Cloaked",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloakedxyz/clkd-stealth.git"
  },
  "bugs": {
    "url": "https://github.com/cloakedxyz/clkd-stealth/issues"
  },
  "homepage": "https://github.com/cloakedxyz/clkd-stealth#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.18.0",
  "dependencies": {
    "@noble/secp256k1": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "viem": "^2.39.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitest/ui": "^4.0.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.10"
  }
}
